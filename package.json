{
  "name": "astro-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "sync:assets": "cp node_modules/98.css/dist/98.css public/98.css && esbuild scripts/feed-style.js --minify --outfile=public/feed-style.js",
    "dev": "pnpm sync:assets && astro dev",
    "build": "pnpm sync:assets && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "98.css": "^0.1.21",
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.5",
    "markdown-it": "^14.3.0",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "smol-toml@<1.6.1": ">=1.6.1",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
