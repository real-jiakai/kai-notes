---
interface Props {
	date: Date;
	lang?: 'zh' | 'en';
}

const { date, lang = 'zh' } = Astro.props;
const locale = lang === 'zh' ? 'zh-CN' : 'en-US';

// ISO 日期解析为 UTC 零点，展示与 datetime 都按 UTC 取日历日期，任意时区构建结果一致
const isoDate = date.toISOString().slice(0, 10);
---

<time datetime={isoDate}>
	{
		date.toLocaleDateString(locale, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
			timeZone: 'UTC',
		})
	}
</time>
