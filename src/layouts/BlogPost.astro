---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BackToTop from '../components/BackToTop.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { getPostPath } from '../utils/posts';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	lang?: Lang;
	headings?: MarkdownHeading[];
};

const { title, description, pubDate, updatedDate, prevPost, nextPost, lang: propLang, headings } =
	Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
	<head>
		<BaseHead title={title} description={description} pubDate={pubDate} updatedDate={updatedDate} />
		<style>
			html, body {
				height: 100%;
				margin: 0;
				padding: 0;
			}
			
			body {
				background: var(--desktop);
				font-family: 'MS Sans Serif', sans-serif;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			
			.desktop {
				/* 显式宽度：避免按内容固有宽度收缩适配（margin auto 会禁用 flex stretch），
				   否则宽表格等内容会把不同语言的页面撑成不同宽度 */
				width: 100%;
				box-sizing: border-box;
				max-width: 840px; /* 800px 内容 + 40px padding */
				margin: 0 auto;
				padding: 0 20px;
				flex: 1;
				display: flex;
				min-width: 0;
				position: relative; /* 右侧目录轨道的定位基准 */
			}

			.window {
				flex: 1;
				display: flex;
				flex-direction: column;
				min-width: 0;
			}
			
			.window-body {
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			
			.article-content {
				flex: 1;
			}
			
			.article-header {
				padding: 15px;
				border-bottom: 1px solid var(--border);
				margin-bottom: 15px;
			}

			.article-title {
				margin: 0 0 10px 0;
				color: var(--heading);
				font-size: 18px;
				font-weight: bold;
			}

			.article-date {
				color: var(--text);
				font-size: 12px;
				margin: 5px 0;
			}

			.article-content {
				padding: 15px;
				line-height: 1.75;
				color: var(--text);
			}
			
			.article-navigation {
				margin-top: 20px;
				padding: 15px;
				border-top: 1px solid var(--border);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			
			.nav-link {
				color: var(--text);
				text-decoration: none;
				padding: 6px 12px;
				border: 1px solid transparent;
				background: var(--surface);
				display: inline-block;
				font-size: 14px;
				max-width: 200px;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				box-shadow: inset -1px -1px var(--bevel-dark-outer), inset 1px 1px var(--bevel-light-outer);
			}

			.nav-link:hover {
				box-shadow: inset -1px -1px var(--bevel-light-outer), inset 1px 1px var(--bevel-dark-outer);
			}

			.nav-link.disabled {
				color: var(--text-muted);
				border: 1px solid var(--border);
				background: var(--code-bg);
				cursor: not-allowed;
				box-shadow: none;
			}
			
			.nav-placeholder {
				width: 200px;
			}

			/* Comments section */
			.article-comments {
				margin-top: 20px;
				padding: 15px;
				border-top: 1px solid var(--border);
			}

			.comments-title {
				color: var(--heading);
				font-size: 16px;
				margin: 0 0 15px 0;
			}

			/* Utterances iframe styling */
			.utterances {
				max-width: 100% !important;
			}

			/* Mobile responsive */
			@media (max-width: 600px) {
				.desktop {
					padding: 0 12px;
				}

				.article-header {
					padding: 12px;
				}

				.article-title {
					font-size: 16px;
				}

				.article-content {
					padding: 12px;
				}

				.article-navigation {
					flex-direction: column;
					gap: 10px;
					padding: 12px;
				}

				.nav-link {
					max-width: none;
					white-space: normal;
					text-align: center;
					font-size: 13px;
					padding: 8px 12px;
				}

				.nav-placeholder {
					display: none;
				}
			}
		</style>
	</head>

	<body>
		<Navigation lang={lang} />
		<div class="desktop">
			<!-- 目录放在正文前：键盘用户不必先穿过全文才能到达；视觉位置由绝对定位决定，不受 DOM 顺序影响 -->
			<TableOfContents headings={headings ?? []} lang={lang} />
			<div class="window">
				<div class="title-bar">
					<div class="title-bar-text">{t('article.reading')}</div>
				</div>
				<div class="window-body">
					<div class="article-header">
						<h1 class="article-title">{title}</h1>
						<div class="article-date">
							{t('article.published')}: <FormattedDate date={pubDate} lang={lang} />
						</div>
						{updatedDate && (
							<div class="article-date">
								{t('article.updated')}: <FormattedDate date={updatedDate} lang={lang} />
							</div>
						)}
					</div>
					<div
						class="article-content"
						data-label-copy={t('code.copy')}
						data-label-copied={t('code.copied')}
						data-label-copy-failed={t('code.copyFailed')}
					>
						<slot />
					</div>
					<!-- 复制按钮的读屏播报区：aria-label 变化对未聚焦按钮不播报，live region 才可靠 -->
					<div id="copy-feedback" role="status" class="sr-only"></div>
					<div class="article-navigation">
						<div>
							{prevPost ? (
								<a href={getPostPath(prevPost)} class="nav-link" title={prevPost.data.title}>
									← {t('article.prev')}: {prevPost.data.title}
								</a>
							) : (
								<div class="nav-placeholder"></div>
							)}
						</div>
						<div>
							{nextPost ? (
								<a href={getPostPath(nextPost)} class="nav-link" title={nextPost.data.title}>
									{t('article.next')}: {nextPost.data.title} →
								</a>
							) : (
								<div class="nav-placeholder"></div>
							)}
						</div>
					</div>
					<!-- Comments Section（utterances 动态注入，初始主题跟随当前模式） -->
					<div class="article-comments">
						<h3 class="comments-title">{t('comments.title')}</h3>
						<div id="utterances-container"></div>
					</div>
				</div>
			</div>
		</div>
		<Footer lang={lang} />

		<!-- Lightbox 图片放大浮层 -->
		<div class="lightbox-overlay" id="lightbox">
			<div class="lightbox-window">
				<div class="lightbox-title-bar">
					<span class="lightbox-title-bar-text">{t('lightbox.preview')}</span>
					<button class="lightbox-close-btn" id="lightbox-close" aria-label={t('lightbox.close')}>×</button>
				</div>
				<figure class="lightbox-body">
					<img id="lightbox-img" src="" alt={t('lightbox.preview')} />
					<figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
				</figure>
			</div>
		</div>

		<script>
			// utterances 评论：动态注入以匹配当前主题；切换时由 Navigation 的脚本 postMessage 同步
			const utterancesContainer = document.getElementById('utterances-container');
			if (utterancesContainer) {
				const utterances = document.createElement('script');
				utterances.src = 'https://utteranc.es/client.js';
				utterances.setAttribute('repo', 'real-jiakai/kai-notes');
				utterances.setAttribute('issue-term', 'pathname');
				utterances.setAttribute('label', 'comment');
				utterances.setAttribute(
					'theme',
					document.documentElement.dataset.theme === 'dark' ? 'github-dark' : 'github-light'
				);
				utterances.setAttribute('crossorigin', 'anonymous');
				utterances.async = true;
				utterancesContainer.appendChild(utterances);
			}

			// Lightbox 功能
			const lightbox = document.getElementById('lightbox');
			const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
			const lightboxCaption = document.getElementById('lightbox-caption');
			const closeBtn = document.getElementById('lightbox-close');
			// 服务端已按语言渲染初始 alt，作为无 alt 图片的本地化兜底
			const fallbackAlt = lightboxImg.alt;

			// 为所有文章图片添加点击事件
			document.querySelectorAll('.article-content img').forEach(img => {
				img.addEventListener('click', (e) => {
					const target = e.target as HTMLImageElement;
					lightboxImg.src = target.src;
					const altText = target.alt?.trim();
					lightboxImg.alt = altText || fallbackAlt;
					// Display alt text as caption
					if (lightboxCaption) {
						lightboxCaption.textContent = altText || '';
						lightboxCaption.style.display = altText ? 'block' : 'none';
					}
					lightbox?.classList.add('active');
				});
			});

			// 关闭 lightbox
			function closeLightbox() {
				lightbox?.classList.remove('active');
			}

			closeBtn?.addEventListener('click', closeLightbox);

			// 点击遮罩层关闭
			lightbox?.addEventListener('click', (e) => {
				if (e.target === lightbox) {
					closeLightbox();
				}
			});

			// ESC 键关闭
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && lightbox?.classList.contains('active')) {
					closeLightbox();
				}
			});
		</script>

		<script>
			// 代码块复制按钮：包一层定位容器，hover/聚焦时显示（触屏常显）
			const copyIcon =
				'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="12" height="12"/><path d="M5 15H3V3h12v2"/></svg>';
			const checkIcon =
				'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';
			const failIcon =
				'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>';

			// 剪贴板 API 不可用（非安全上下文/老浏览器）时干脆不注入按钮，避免摆设
			const content =
				typeof navigator.clipboard?.writeText === 'function'
					? document.querySelector('.article-content')
					: null;
			const copyLabel = content?.getAttribute('data-label-copy') || 'Copy code';
			const copiedLabel = content?.getAttribute('data-label-copied') || 'Copied!';
			const failedLabel = content?.getAttribute('data-label-copy-failed') || 'Copy failed';
			const feedbackRegion = document.getElementById('copy-feedback');

			// 先清空再延迟写入：连续复制时文本相同，不清空则 live region 不会重新播报
			const announce = (label: string) => {
				if (!feedbackRegion) return;
				feedbackRegion.textContent = '';
				window.setTimeout(() => {
					feedbackRegion.textContent = label;
				}, 30);
			};

			content?.querySelectorAll('pre').forEach((pre) => {
				const wrapper = document.createElement('div');
				wrapper.className = 'code-block';
				pre.replaceWith(wrapper);
				wrapper.append(pre);

				const button = document.createElement('button');
				button.type = 'button';
				button.className = 'copy-btn';
				button.title = copyLabel;
				button.setAttribute('aria-label', copyLabel);
				button.innerHTML = copyIcon;

				let restore = 0;
				const flash = (label: string, icon: string) => {
					button.innerHTML = icon;
					button.title = label;
					button.setAttribute('aria-label', label);
					button.classList.add('feedback');
					announce(label);
					window.clearTimeout(restore);
					restore = window.setTimeout(() => {
						button.innerHTML = copyIcon;
						button.title = copyLabel;
						button.setAttribute('aria-label', copyLabel);
						button.classList.remove('feedback');
					}, 2000);
				};

				button.addEventListener('click', async () => {
					const code = pre.querySelector('code');
					const text = (code ?? pre).textContent?.replace(/\n$/, '') ?? '';
					try {
						await navigator.clipboard.writeText(text);
						flash(copiedLabel, checkIcon);
					} catch {
						flash(failedLabel, failIcon);
					}
				});

				wrapper.append(button);
			});
		</script>

		<BackToTop lang={lang} />
	</body>
</html>
