---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BackToTop from '../components/BackToTop.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { getPostPath } from '../utils/posts';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	lang?: Lang;
	headings?: MarkdownHeading[];
};

const {
	title,
	description,
	seoTitle,
	seoDescription,
	pubDate,
	updatedDate,
	heroImage,
	prevPost,
	nextPost,
	lang: propLang,
	headings,
} = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const socialImage = typeof heroImage === 'string' ? heroImage : heroImage?.src;
---

<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
	<head>
		<BaseHead
			title={title}
			description={description}
			seoTitle={seoTitle}
			seoDescription={seoDescription}
			pubDate={pubDate}
			updatedDate={updatedDate}
			image={socialImage}
			imageAlt={title}
		/>
		<style>
			html, body {
				height: 100%;
				margin: 0;
				padding: 0;
			}
			
			body {
				background: var(--desktop);
				font-family: 'MS Sans Serif', sans-serif;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			
			.desktop {
				/* 显式宽度：避免按内容固有宽度收缩适配（margin auto 会禁用 flex stretch），
				   否则宽表格等内容会把不同语言的页面撑成不同宽度 */
				width: 100%;
				box-sizing: border-box;
				max-width: 840px; /* 800px 内容 + 40px padding */
				margin: 0 auto;
				padding: 0 20px;
				flex: 1;
				display: flex;
				min-width: 0;
				position: relative; /* 右侧目录轨道的定位基准 */
			}

			.window {
				flex: 1;
				display: flex;
				flex-direction: column;
				min-width: 0;
			}
			
			.window-body {
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			
			.article-content {
				flex: 1;
			}
			
			.article-header {
				padding: 15px;
				border-bottom: 1px solid var(--border);
				margin-bottom: 15px;
			}

			.article-title {
				margin: 0 0 10px 0;
				color: var(--heading);
				font-size: 18px;
				font-weight: bold;
			}

			.article-date {
				color: var(--text);
				font-size: 12px;
				margin: 5px 0;
			}

			.article-content {
				padding: 15px;
				line-height: 1.75;
				color: var(--text);
			}
			
			.article-navigation {
				margin-top: 20px;
				padding: 15px;
				border-top: 1px solid var(--border);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			
			.nav-link {
				color: var(--text);
				text-decoration: none;
				padding: 6px 12px;
				border: 1px solid transparent;
				background: var(--surface);
				display: inline-block;
				font-size: 14px;
				max-width: 200px;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				box-shadow: inset -1px -1px var(--bevel-dark-outer), inset 1px 1px var(--bevel-light-outer);
			}

			.nav-link:hover {
				box-shadow: inset -1px -1px var(--bevel-light-outer), inset 1px 1px var(--bevel-dark-outer);
			}

			.nav-link.disabled {
				color: var(--text-muted);
				border: 1px solid var(--border);
				background: var(--code-bg);
				cursor: not-allowed;
				box-shadow: none;
			}
			
			.nav-placeholder {
				width: 200px;
			}

			/* Comments section */
			.article-comments {
				margin-top: 20px;
				padding: 15px;
				border-top: 1px solid var(--border);
			}

			.comments-title {
				color: var(--heading);
				font-size: 16px;
				margin: 0 0 15px 0;
			}

			/* Utterances iframe styling */
			.utterances {
				max-width: 100% !important;
			}

			/* Mobile responsive */
			@media (max-width: 600px) {
				.desktop {
					padding: 0 12px;
				}

				.article-header {
					padding: 12px;
				}

				.article-title {
					font-size: 16px;
				}

				.article-content {
					padding: 12px;
				}

				.article-navigation {
					flex-direction: column;
					gap: 10px;
					padding: 12px;
				}

				.nav-link {
					max-width: none;
					white-space: normal;
					text-align: center;
					font-size: 13px;
					padding: 8px 12px;
				}

				.nav-placeholder {
					display: none;
				}
			}
		</style>
	</head>

	<body>
		<Navigation lang={lang} />
		<main id="main-content" class="desktop" tabindex="-1">
			<!-- 目录放在正文前：键盘用户不必先穿过全文才能到达；视觉位置由绝对定位决定，不受 DOM 顺序影响 -->
			<TableOfContents headings={headings ?? []} lang={lang} />
			<article class="window" aria-labelledby="article-title">
				<div class="title-bar">
					<div class="title-bar-text">{t('article.reading')}</div>
				</div>
				<div class="window-body">
					<header class="article-header">
						<h1 class="article-title" id="article-title">{title}</h1>
						<div class="article-date">
							{t('article.published')}: <FormattedDate date={pubDate} lang={lang} />
						</div>
						{updatedDate && (
							<div class="article-date">
								{t('article.updated')}: <FormattedDate date={updatedDate} lang={lang} />
							</div>
						)}
					</header>
					<div
						class="article-content"
						data-label-copy={t('code.copy')}
						data-label-copied={t('code.copied')}
						data-label-copy-failed={t('code.copyFailed')}
						data-label-open-image={t('lightbox.open')}
					>
						<slot />
					</div>
					<!-- 复制按钮的读屏播报区：aria-label 变化对未聚焦按钮不播报，live region 才可靠 -->
					<div id="copy-feedback" role="status" class="sr-only"></div>
					<nav class="article-navigation" aria-label={t('article.navigation')}>
						<div>
							{prevPost ? (
								<a href={getPostPath(prevPost)} class="nav-link" title={prevPost.data.title}>
									← {t('article.prev')}: {prevPost.data.title}
								</a>
							) : (
								<div class="nav-placeholder"></div>
							)}
						</div>
						<div>
							{nextPost ? (
								<a href={getPostPath(nextPost)} class="nav-link" title={nextPost.data.title}>
									{t('article.next')}: {nextPost.data.title} →
								</a>
							) : (
								<div class="nav-placeholder"></div>
							)}
						</div>
					</nav>
					<!-- Comments Section（utterances 动态注入，初始主题跟随当前模式） -->
					<section class="article-comments" aria-labelledby="comments-title">
						<h2 class="comments-title" id="comments-title">{t('comments.title')}</h2>
						<div id="utterances-container"></div>
					</section>
				</div>
			</article>
		</main>
		<Footer lang={lang} />

		<!-- Lightbox 图片放大浮层 -->
		<div class="lightbox-overlay" id="lightbox" hidden>
			<div
				class="lightbox-window"
				id="lightbox-dialog"
				role="dialog"
				aria-modal="true"
				aria-labelledby="lightbox-title"
				tabindex="-1"
			>
				<div class="lightbox-title-bar">
					<span class="lightbox-title-bar-text" id="lightbox-title">{t('lightbox.preview')}</span>
					<button type="button" class="lightbox-close-btn" id="lightbox-close" aria-label={t('lightbox.close')}>×</button>
				</div>
				<figure class="lightbox-body">
					<img id="lightbox-img" alt={t('lightbox.preview')} />
					<figcaption id="lightbox-caption" class="lightbox-caption" hidden></figcaption>
				</figure>
			</div>
		</div>

		<script>
			// utterances 评论：动态注入以匹配当前主题；切换时由 Navigation 的脚本 postMessage 同步
			const utterancesContainer = document.getElementById('utterances-container');
			if (utterancesContainer) {
				const utterances = document.createElement('script');
				utterances.src = 'https://utteranc.es/client.js';
				utterances.setAttribute('repo', 'real-jiakai/kai-notes');
				utterances.setAttribute('issue-term', 'pathname');
				utterances.setAttribute('label', 'comment');
				utterances.setAttribute(
					'theme',
					document.documentElement.dataset.theme === 'dark' ? 'github-dark' : 'github-light'
				);
				utterances.setAttribute('crossorigin', 'anonymous');
				utterances.async = true;
				utterancesContainer.appendChild(utterances);
			}

			// Lightbox：完整的键盘、焦点与模态背景管理。
			const lightbox = document.getElementById('lightbox') as HTMLElement | null;
			const lightboxDialog = document.getElementById('lightbox-dialog') as HTMLElement | null;
			const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
			const lightboxCaption = document.getElementById('lightbox-caption') as HTMLElement | null;
			const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement | null;
			const articleContent = document.querySelector('.article-content') as HTMLElement | null;
			const fallbackAlt = lightboxImg?.alt || 'Image preview';
			const openImageLabel = articleContent?.dataset.labelOpenImage || 'Open image preview: {alt}';
			const focusableSelector = [
				'a[href]',
				'button:not([disabled])',
				'input:not([disabled])',
				'select:not([disabled])',
				'textarea:not([disabled])',
				'[tabindex]:not([tabindex="-1"])',
			].join(',');

			let lightboxTrigger: HTMLElement | null = null;
			let inertBackground: HTMLElement[] = [];
			let previousBodyOverflow = '';
			let previousBodyPaddingRight = '';

			const lightboxIsOpen = () => Boolean(lightbox && !lightbox.hidden);

			function lockBackground() {
				if (!lightbox) return;
				previousBodyOverflow = document.body.style.overflow;
				previousBodyPaddingRight = document.body.style.paddingRight;
				const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
				document.body.style.overflow = 'hidden';
				if (scrollbarWidth > 0) {
					document.body.style.paddingRight = `${scrollbarWidth}px`;
				}

				inertBackground = Array.from(document.body.children).filter(
					(element): element is HTMLElement =>
						element instanceof HTMLElement && element !== lightbox && !element.hasAttribute('inert')
				);
				inertBackground.forEach((element) => element.setAttribute('inert', ''));
			}

			function unlockBackground() {
				inertBackground.forEach((element) => element.removeAttribute('inert'));
				inertBackground = [];
				document.body.style.overflow = previousBodyOverflow;
				document.body.style.paddingRight = previousBodyPaddingRight;
			}

			function openLightbox(trigger: HTMLImageElement) {
				if (!lightbox || !lightboxDialog || !lightboxImg || !closeBtn) return;
				const source = trigger.currentSrc || trigger.src;
				if (!source) return;

				lightboxTrigger = trigger;
				const altText = trigger.alt?.trim() || '';
				lightboxImg.src = source;
				lightboxImg.alt = altText || fallbackAlt;
				if (lightboxCaption) {
					lightboxCaption.textContent = altText;
					lightboxCaption.hidden = !altText;
				}

				lightbox.hidden = false;
				lightbox.classList.add('active');
				lockBackground();
				window.requestAnimationFrame(() => closeBtn.focus());
			}

			function closeLightbox() {
				if (!lightboxIsOpen() || !lightbox || !lightboxImg) return;
				lightbox.classList.remove('active');
				lightbox.hidden = true;
				lightboxImg.removeAttribute('src');
				if (lightboxCaption) {
					lightboxCaption.textContent = '';
					lightboxCaption.hidden = true;
				}
				unlockBackground();

				const trigger = lightboxTrigger;
				lightboxTrigger = null;
				if (trigger?.isConnected) {
					trigger.focus({ preventScroll: true });
				}
			}

			// Article images behave as buttons unless the author already placed one inside a link/button.
			document.querySelectorAll<HTMLImageElement>('.article-content img').forEach((image) => {
				if (image.closest('a[href], button')) return;
				const altText = image.alt?.trim() || fallbackAlt;
				image.tabIndex = 0;
				image.setAttribute('role', 'button');
				image.setAttribute('aria-haspopup', 'dialog');
				image.setAttribute('aria-controls', 'lightbox-dialog');
				image.setAttribute('aria-label', openImageLabel.replace('{alt}', altText));
				image.addEventListener('click', () => openLightbox(image));
				image.addEventListener('keydown', (event) => {
					if (event.key === 'Enter' || event.key === ' ') {
						event.preventDefault();
						openLightbox(image);
					}
				});
			});

			closeBtn?.addEventListener('click', closeLightbox);

			// Clicking only the backdrop (not the dialog itself) dismisses it.
			lightbox?.addEventListener('click', (event) => {
				if (event.target === lightbox) closeLightbox();
			});

			document.addEventListener('keydown', (event) => {
				if (!lightboxIsOpen() || !lightboxDialog) return;
				if (event.key === 'Escape') {
					event.preventDefault();
					closeLightbox();
					return;
				}

				if (event.key !== 'Tab') return;
				const focusable = Array.from(lightboxDialog.querySelectorAll<HTMLElement>(focusableSelector)).filter(
					(element) => !element.hidden && element.getAttribute('aria-hidden') !== 'true'
				);
				if (focusable.length === 0) {
					event.preventDefault();
					lightboxDialog.focus();
					return;
				}

				const first = focusable[0];
				const last = focusable[focusable.length - 1];
				if (event.shiftKey && (document.activeElement === first || !lightboxDialog.contains(document.activeElement))) {
					event.preventDefault();
					last.focus();
				} else if (!event.shiftKey && (document.activeElement === last || !lightboxDialog.contains(document.activeElement))) {
					event.preventDefault();
					first.focus();
				}
			});
		</script>

		<script>
			// 代码块复制按钮：包一层定位容器，hover/聚焦时显示（触屏常显）
			const copyIcon =
				'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="12" height="12"/><path d="M5 15H3V3h12v2"/></svg>';
			const checkIcon =
				'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';
			const failIcon =
				'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>';

			// 剪贴板 API 不可用（非安全上下文/老浏览器）时干脆不注入按钮，避免摆设
			const content =
				typeof navigator.clipboard?.writeText === 'function'
					? document.querySelector('.article-content')
					: null;
			const copyLabel = content?.getAttribute('data-label-copy') || 'Copy code';
			const copiedLabel = content?.getAttribute('data-label-copied') || 'Copied!';
			const failedLabel = content?.getAttribute('data-label-copy-failed') || 'Copy failed';
			const feedbackRegion = document.getElementById('copy-feedback');

			// 先清空再延迟写入：连续复制时文本相同，不清空则 live region 不会重新播报
			const announce = (label: string) => {
				if (!feedbackRegion) return;
				feedbackRegion.textContent = '';
				window.setTimeout(() => {
					feedbackRegion.textContent = label;
				}, 30);
			};

			content?.querySelectorAll('pre').forEach((pre) => {
				const wrapper = document.createElement('div');
				wrapper.className = 'code-block';
				pre.replaceWith(wrapper);
				wrapper.append(pre);

				const button = document.createElement('button');
				button.type = 'button';
				button.className = 'copy-btn';
				button.title = copyLabel;
				button.setAttribute('aria-label', copyLabel);
				button.innerHTML = copyIcon;

				let restore = 0;
				const flash = (label: string, icon: string) => {
					button.innerHTML = icon;
					button.title = label;
					button.setAttribute('aria-label', label);
					button.classList.add('feedback');
					announce(label);
					window.clearTimeout(restore);
					restore = window.setTimeout(() => {
						button.innerHTML = copyIcon;
						button.title = copyLabel;
						button.setAttribute('aria-label', copyLabel);
						button.classList.remove('feedback');
					}, 2000);
				};

				button.addEventListener('click', async () => {
					const code = pre.querySelector('code');
					const text = (code ?? pre).textContent?.replace(/\n$/, '') ?? '';
					try {
						await navigator.clipboard.writeText(text);
						flash(copiedLabel, checkIcon);
					} catch {
						flash(failedLabel, failIcon);
					}
				});

				wrapper.append(button);
			});
		</script>

		<BackToTop lang={lang} />
	</body>
</html>
