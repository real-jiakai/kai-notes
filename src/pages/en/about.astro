---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
import { SITE_TITLE_I18N } from '../../consts';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const SITE_TITLE = SITE_TITLE_I18N[lang];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${t('about.title')} - ${SITE_TITLE}`} description={t('about.description')} />
	</head>
	<body>
		<Navigation lang={lang} />
		<main id="main-content" class="desktop" tabindex="-1">
			<div class="window">
				<div class="title-bar">
					<div class="title-bar-text">{t('about.title')}</div>
				</div>
				<div class="window-body">
					<h1>{t('about.title')}</h1>
					<p>{t('about.description')}</p>

					<h2>{t('about.techStack')}</h2>
					<ul>
						<li>{t('about.astro')}</li>
						<li>{t('about.98css')}</li>
					</ul>
				</div>
			</div>
		</main>
		<Footer lang={lang} />
		<BackToTop lang={lang} />
	</body>
</html>

<style>
	html, body {
		height: 100%;
		margin: 0;
		padding: 0;
	}

	body {
		background: var(--desktop);
		font-family: 'MS Sans Serif', sans-serif;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	.desktop {
		/* 同 BlogPost：显式宽度避免按内容收缩；flex:1 把 footer 推到视口底部 */
		width: 100%;
		box-sizing: border-box;
		max-width: 840px; /* 800px 内容 + 40px padding */
		margin: 0 auto;
		padding: 0 20px;
		flex: 1;
	}

	.window {
		display: flex;
		flex-direction: column;
		margin-bottom: 20px;
	}

	.window-body {
		padding: 20px;
	}

	h1, h2 {
		color: var(--heading);
		margin: 20px 0 10px 0;
	}

	h1 {
		font-size: 2.441em;
	}

	h2 {
		font-size: 1.953em;
	}

	p, li {
		line-height: 1.6;
		margin: 10px 0;
	}

	ul {
		padding-left: 20px;
	}

	@media (max-width: 600px) {
		.desktop {
			padding: 0 12px;
		}

		.window-body {
			padding: 15px 12px;
		}

		h1 {
			font-size: 18px;
		}

		h2 {
			font-size: 16px;
		}
	}
</style>
