---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
import { SITE_TITLE_I18N, SITE_DESCRIPTION_I18N, POSTS_PER_PAGE } from '../../consts';
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { useTranslations } from '../../i18n/utils';
import type { Page, PaginateFunction } from 'astro';

const lang = 'en';
const t = useTranslations(lang);
const SITE_DESCRIPTION = SITE_DESCRIPTION_I18N[lang];

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
	const posts = (await getCollection('blog', ({ data }) => {
		// Filter out drafts, only show English posts
		return data.draft !== true && data.lang === 'en';
	})).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

	return paginate(posts, { pageSize: POSTS_PER_PAGE });
}

type Props = {
	page: Page<CollectionEntry<'blog'>>;
};

const { page } = Astro.props;

// Page 1 (the /en/ homepage) keeps the site title; later pages show the page number
const isFirstPage = page.currentPage === 1;
const pageTitle = isFirstPage ? SITE_TITLE_I18N[lang] : t('article.list.page', { page: page.currentPage });
const titleBarText = isFirstPage ? t('article.list') : t('article.list.page', { page: page.currentPage });
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={SITE_DESCRIPTION} />
		<style>
			html, body {
				height: 100%;
				margin: 0;
				padding: 0;
			}

			body {
				background: var(--desktop);
				font-family: 'MS Sans Serif', sans-serif;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}

			.desktop {
				max-width: 800px;
				margin: 0 auto;
				padding: 0 20px;
			}

			.window {
				display: flex;
				flex-direction: column;
				margin-bottom: 20px;
			}

			.window-body {
				display: flex;
				flex-direction: column;
			}

			.article-list {
				margin-bottom: 20px;
			}

			.article-item {
				padding: 16px 30px;
				border-bottom: 1px solid var(--border);
				margin-bottom: 8px;
			}

			.article-item-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 10px;
			}

			.article-desc {
				margin: 8px 0 0 0;
				font-size: 14px;
				line-height: 1.6;
				color: var(--text-secondary);
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.article-item:last-child {
				border-bottom: none;
			}

			.article-title {
				color: var(--link);
				text-decoration: none;
				font-weight: bold;
				flex: 1;
				font-size: 18px;
				line-height: 1.5;
			}

			.article-title:hover {
				text-decoration: underline;
			}

			.article-date {
				color: var(--text-muted);
				font-size: 14px;
				margin-left: 40px;
				white-space: nowrap;
				min-width: 120px;
			}

			.pagination {
				text-align: center;
				margin-top: 20px;
			}

			.pagination a,
			.pagination span {
				margin: 0 5px;
				padding: 2px 8px;
				text-decoration: none;
				color: var(--text);
			}

			.pagination .current {
				font-weight: bold;
				background: var(--titlebar-1);
				color: #ffffff;
			}

			/* Mobile responsive */
			@media (max-width: 600px) {
				.desktop {
					padding: 0 12px;
				}

				.article-item {
					padding: 15px 12px;
				}

				.article-item-header {
					flex-direction: column;
					align-items: flex-start;
					gap: 6px;
				}

				.article-title {
					font-size: 16px;
				}

				.article-date {
					margin-left: 0;
					min-width: auto;
					font-size: 12px;
				}

				.pagination {
					display: flex;
					flex-wrap: wrap;
					justify-content: center;
					gap: 4px;
				}

				.pagination a,
				.pagination span {
					margin: 0;
					padding: 4px 8px;
				}
			}
		</style>
	</head>
	<body>
		<Navigation lang={lang} />
		<div class="desktop">
			<div class="window">
				<div class="title-bar">
					<div class="title-bar-text">{titleBarText}</div>
				</div>
				<div class="window-body">
					<div class="article-list">
						{page.data.map((post) => {
							const date = new Date(post.data.pubDate);
							const year = date.getFullYear();
							const month = (date.getMonth() + 1).toString().padStart(2, '0');
							const slug = post.data.slug || post.id.replace(/^en\//, '');

							return (
								<div class="article-item">
									<div class="article-item-header">
										<a href={`/en/${year}/${month}/${slug}/`} class="article-title">
											{post.data.title}
										</a>
										<span class="article-date">
											<FormattedDate date={post.data.pubDate} lang={lang} />
										</span>
									</div>
									{post.data.description !== post.data.title && (
									<p class="article-desc">{post.data.description}</p>
								)}
								</div>
							);
						})}
					</div>

					{page.lastPage > 1 && (
						<div class="pagination">
							{page.url.prev && (
								<a href={page.url.prev} class="button">{t('pagination.prev')}</a>
							)}

							{Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => (
								pageNum === page.currentPage ? (
									<span class="current">{pageNum}</span>
								) : (
									<a href={pageNum === 1 ? '/en/' : `/en/${pageNum}/`}>{pageNum}</a>
								)
							))}

							{page.url.next && (
								<a href={page.url.next} class="button">{t('pagination.next')}</a>
							)}
						</div>
					)}
				</div>
			</div>
		</div>
		<Footer lang={lang} />
		<BackToTop lang={lang} />
	</body>
</html>
