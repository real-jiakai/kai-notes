---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import { SITE_TITLE_I18N, SITE_DESCRIPTION_I18N, POSTS_PER_PAGE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);
const SITE_TITLE = SITE_TITLE_I18N[lang];
const SITE_DESCRIPTION = SITE_DESCRIPTION_I18N[lang];

const posts = (await getCollection('blog', ({ data }) => {
	// 过滤掉草稿文章，只显示中文文章
	return data.draft !== true && (data.lang === 'zh' || data.lang === undefined);
})).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, POSTS_PER_PAGE); // 只显示第一页文章

const allPosts = await getCollection('blog', ({ data }) => {
	// 过滤掉草稿文章，只显示中文文章
	return data.draft !== true && (data.lang === 'zh' || data.lang === undefined);
});
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			html, body {
				height: 100%;
				margin: 0;
				padding: 0;
			}

			body {
				background: var(--desktop);
				font-family: 'MS Sans Serif', sans-serif;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}

			.desktop {
				max-width: 800px;
				margin: 0 auto;
				padding: 0 20px;
			}

			.window {
				display: flex;
				flex-direction: column;
				margin-bottom: 20px;
			}

			.window-body {
				display: flex;
				flex-direction: column;
			}

			.article-list {
				margin-bottom: 20px;
			}

			.article-item {
				padding: 16px 30px;
				border-bottom: 1px solid var(--border);
				margin-bottom: 8px;
			}

			.article-item-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 10px;
			}

			.article-desc {
				margin: 8px 0 0 0;
				font-size: 14px;
				line-height: 1.6;
				color: var(--text-secondary);
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.article-item:last-child {
				border-bottom: none;
			}

			.article-title {
				color: var(--link);
				text-decoration: none;
				font-weight: bold;
				flex: 1;
				font-size: 18px;
				line-height: 1.5;
			}

			.article-title:hover {
				text-decoration: underline;
			}

			.article-date {
				color: var(--text-muted);
				font-size: 14px;
				margin-left: 40px;
				white-space: nowrap;
				min-width: 120px;
			}

			.pagination {
				text-align: center;
				margin-top: 20px;
			}

			.pagination a,
			.pagination span {
				margin: 0 5px;
				padding: 2px 8px;
				text-decoration: none;
				color: var(--text);
			}

			.pagination .current {
				font-weight: bold;
				background: var(--titlebar-1);
				color: #ffffff;
			}

			/* Mobile responsive */
			@media (max-width: 600px) {
				.desktop {
					padding: 0 12px;
				}

				.article-item {
					padding: 15px 12px;
				}

				.article-item-header {
					flex-direction: column;
					align-items: flex-start;
					gap: 6px;
				}

				.article-title {
					font-size: 16px;
				}

				.article-date {
					margin-left: 0;
					min-width: auto;
					font-size: 12px;
				}

				.pagination {
					display: flex;
					flex-wrap: wrap;
					justify-content: center;
					gap: 4px;
				}

				.pagination a,
				.pagination span {
					margin: 0;
					padding: 4px 8px;
				}
			}
		</style>
	</head>
	<body>
		<Navigation lang={lang} />
		<div class="desktop">
			<div class="window">
				<div class="title-bar">
					<div class="title-bar-text">{t('article.list')}</div>
				</div>
				<div class="window-body">
					<div class="article-list">
						{posts.map((post) => {
							const date = new Date(post.data.pubDate);
							const year = date.getFullYear();
							const month = (date.getMonth() + 1).toString().padStart(2, '0');

							return (
								<div class="article-item">
									<div class="article-item-header">
										<a href={`/${year}/${month}/${post.data.slug || post.id}/`} class="article-title">
											{post.data.title}
										</a>
										<span class="article-date">
											<FormattedDate date={post.data.pubDate} lang={lang} />
										</span>
									</div>
									{post.data.description !== post.data.title && (
									<p class="article-desc">{post.data.description}</p>
								)}
								</div>
							);
						})}
					</div>

					{totalPages > 1 && (
						<div class="pagination">
							<span class="current">1</span>
							{Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map((pageNum) => (
								<a href={`/${pageNum}/`}>{pageNum}</a>
							))}
							{totalPages > 1 && (
								<a href="/2/" class="button">{t('pagination.next')}</a>
							)}
						</div>
					)}
				</div>
			</div>
		</div>
		<Footer lang={lang} />
		<BackToTop lang={lang} />
	</body>
</html>
