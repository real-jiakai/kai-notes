---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import { SITE_TITLE_I18N, SITE_DESCRIPTION_I18N, POSTS_PER_PAGE } from '../consts';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { useTranslations } from '../i18n/utils';
import { getPublishedPosts, getPostPath } from '../utils/posts';
import type { Page, PaginateFunction } from 'astro';

const lang = 'zh';
const t = useTranslations(lang);
const SITE_DESCRIPTION = SITE_DESCRIPTION_I18N[lang];

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
	return paginate(await getPublishedPosts('zh'), { pageSize: POSTS_PER_PAGE });
}

type Props = {
	page: Page<CollectionEntry<'blog'>>;
};

const { page } = Astro.props;

// 首页（第 1 页）沿用站点标题，其余分页显示页码
const isFirstPage = page.currentPage === 1;
const pageTitle = isFirstPage ? SITE_TITLE_I18N[lang] : t('article.list.page', { page: page.currentPage });
const titleBarText = isFirstPage ? t('article.list') : t('article.list.page', { page: page.currentPage });

// paginate() 生成的 prev/next 不带尾斜杠，与全站 URL 风格统一
const withTrailingSlash = (url: string) => (url.endsWith('/') ? url : `${url}/`);
const prevUrl = page.url.prev && withTrailingSlash(page.url.prev);
const nextUrl = page.url.next && withTrailingSlash(page.url.next);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={SITE_DESCRIPTION} />
		<style>
			html, body {
				height: 100%;
				margin: 0;
				padding: 0;
			}

			body {
				background: var(--desktop);
				font-family: 'MS Sans Serif', sans-serif;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}

			.desktop {
				/* 同 BlogPost：显式宽度避免按内容收缩；flex:1 把 footer 推到视口底部 */
				width: 100%;
				box-sizing: border-box;
				max-width: 840px; /* 800px 内容 + 40px padding */
				margin: 0 auto;
				padding: 0 20px;
				flex: 1;
			}

			.window {
				display: flex;
				flex-direction: column;
				margin-bottom: 20px;
			}

			.window-body {
				display: flex;
				flex-direction: column;
			}

			.article-list {
				margin-bottom: 20px;
			}

			.article-item {
				padding: 16px 30px;
				border-bottom: 1px solid var(--border);
				margin-bottom: 8px;
			}

			.article-item-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 10px;
			}

			.article-desc {
				margin: 8px 0 0 0;
				font-size: 14px;
				line-height: 1.6;
				color: var(--text-secondary);
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.article-item:last-child {
				border-bottom: none;
			}

			.article-title {
				color: var(--link);
				text-decoration: none;
				font-weight: bold;
				flex: 1;
				font-size: 18px;
				line-height: 1.5;
			}

			.article-title:hover {
				text-decoration: underline;
			}

			.article-date {
				color: var(--text-muted);
				font-size: 14px;
				margin-left: 40px;
				white-space: nowrap;
				min-width: 120px;
			}

			.pagination {
				text-align: center;
				margin-top: 20px;
			}

			.pagination a,
			.pagination span {
				margin: 0 5px;
				padding: 2px 8px;
				text-decoration: none;
				color: var(--text);
			}

			.pagination .current {
				font-weight: bold;
				background: var(--titlebar-1);
				color: #ffffff;
			}

			/* Mobile responsive */
			@media (max-width: 600px) {
				.desktop {
					padding: 0 12px;
				}

				.article-item {
					padding: 15px 12px;
				}

				.article-item-header {
					flex-direction: column;
					align-items: flex-start;
					gap: 6px;
				}

				.article-title {
					font-size: 16px;
				}

				.article-date {
					margin-left: 0;
					min-width: auto;
					font-size: 12px;
				}

				.pagination {
					display: flex;
					flex-wrap: wrap;
					justify-content: center;
					gap: 4px;
				}

				.pagination a,
				.pagination span {
					margin: 0;
					padding: 4px 8px;
				}
			}
		</style>
	</head>
	<body>
		<Navigation lang={lang} />
		<h1 class="sr-only">{pageTitle}</h1>
		<div class="desktop">
			<div class="window">
				<div class="title-bar">
					<div class="title-bar-text">{titleBarText}</div>
				</div>
				<div class="window-body">
					<div class="article-list">
						{page.data.map((post) => {
							return (
								<div class="article-item">
									<div class="article-item-header">
										<a href={getPostPath(post)} class="article-title">
											{post.data.title}
										</a>
										<span class="article-date">
											<FormattedDate date={post.data.pubDate} lang={lang} />
										</span>
									</div>
									{post.data.description !== post.data.title && (
									<p class="article-desc">{post.data.description}</p>
								)}
								</div>
							);
						})}
					</div>

					{page.lastPage > 1 && (
						<div class="pagination">
							{prevUrl && (
								<a href={prevUrl} class="button">{t('pagination.prev')}</a>
							)}

							{Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => (
								pageNum === page.currentPage ? (
									<span class="current">{pageNum}</span>
								) : (
									<a href={pageNum === 1 ? '/' : `/${pageNum}/`}>{pageNum}</a>
								)
							))}

							{nextUrl && (
								<a href={nextUrl} class="button">{t('pagination.next')}</a>
							)}
						</div>
					)}
				</div>
			</div>
		</div>
		<Footer lang={lang} />
		<BackToTop lang={lang} />
	</body>
</html>
